generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  quizAttempts  QuizAttempt[]
  sessions      Session[]
  mastery       UserMastery?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Phase {
  id          String   @id @default(cuid())
  order       Int
  title       String
  description String?
  modules     Module[]
}

model Module {
  id          String  @id @default(cuid())
  phaseId     String
  order       Int
  title       String
  description String?
  phase       Phase   @relation(fields: [phaseId], references: [id])
  topics      Topic[]
}

model Topic {
  id       String        @id @default(cuid())
  moduleId String
  order    Int
  title    String
  slug     String        @unique
  attempts QuizAttempt[]
  module   Module        @relation(fields: [moduleId], references: [id])
}

model Progress {
  chapterId    String    @id
  highestStage StageType @default(UNDERSTAND)
  completedAt  DateTime?
}

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  score     Float
  passed    Boolean
  createdAt DateTime @default(now())
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserMastery {
  id            String   @id @default(cuid())
  userId        String   @unique
  mathScore     Float    @default(0)
  codingScore   Float    @default(0)
  conceptsScore Float    @default(0)
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum StageType {
  UNDERSTAND
  REINFORCE
  PRACTICE
  TEST
  APPLY
}

model Submission {
  id         String    @id @default(cuid())
  topicId    String
  stage      StageType
  userId     String?   // Optional for prototype
  content    String    // The submitted code or math
  result     String?   // The output or result of evaluation
  success    Boolean
  createdAt  DateTime  @default(now())
}
