// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)   

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  quizAttempts  QuizAttempt[]
  mastery       UserMastery?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Learning Engine Models ---

enum StageType {
  UNDERSTAND
  REINFORCE
  TEST
  APPLY
}

model Phase {
  id          String   @id @default(cuid())
  order       Int
  title       String
  description String?
  modules     Module[]
}

model Module {
  id          String   @id @default(cuid())
  phaseId     String
  order       Int
  title       String
  description String?
  phase       Phase    @relation(fields: [phaseId], references: [id])
  topics      Topic[]
}

model Topic {
  id          String          @id @default(cuid())
  moduleId    String
  order       Int
  title       String
  slug        String          @unique
  module      Module          @relation(fields: [moduleId], references: [id])
  attempts    QuizAttempt[]
}

model Progress {
  chapterId   String   @id
  completedAt DateTime @default(now())
}

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  score     Float
  passed    Boolean
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model UserMastery {
  id            String   @id @default(cuid())
  userId        String   @unique
  mathScore     Float    @default(0)
  codingScore   Float    @default(0)
  conceptsScore Float    @default(0)
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
